<% layout('/layouts/boilerplate') -%>

<div class="container my-5">
  <h3 class="fw-bold mb-4">My Bookings 🗓️</h3>

  <% if (bookings.length === 0) { %>
    <div class="text-center py-5">
      <p class="text-muted fs-5">You have no bookings yet.</p>
      <a href="/listings" class="btn btn-danger rounded-3">Explore Listings</a>
    </div>

  <% } else { %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% for (let booking of bookings) { %>
        <div class="col">
          <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">

            <!-- Image -->
            <img
              src="<%= booking.listing.image.url %>"
              alt="<%= booking.listing.title %>"
              class="card-img-top"
              style="height: 200px; object-fit: cover;"
            >

            <!-- Details -->
            <div class="card-body p-3 pb-4">
              <h6 class="fw-bold mb-1">
                <a href="/listings/<%= booking.listing._id %>" 
                   class="text-dark text-decoration-none">
                  <%= booking.listing.title %>
                </a>
              </h6>

              <p class="text-muted small mb-2">
                <%= booking.listing.location %>, <%= booking.listing.country %>
              </p>

              <p class="small mb-1">
                📅 <%= booking.checkIn.toDateString() %> → <%= booking.checkOut.toDateString() %>
              </p>

              <p class="fw-semibold small mb-3">
                ₹<%= booking.totalPrice %> total
              </p>

              <!-- Cancel -->
              <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
               <button class="btn btn-danger btn-sm rounded-3 w-100" 
        style="padding: 8px;">
                  Cancel Booking
                </button>
              </form>

            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</div>